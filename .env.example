# -----------------------------------------------------------------------------
# Database credentials for docker compose (compose.yaml reads this file).
# Local dev can rely on the defaults baked into compose.yaml and skip this.
# In production, copy to `.env`, set a strong password, and keep it OFF git.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=unilink
POSTGRES_PORT=5432

# The app (apps/web/.env) must point DATABASE_URL at this database, e.g.:
#   Local:      postgresql://postgres:postgres@localhost:5432/unilink?schema=public
#   VPS (app in the same compose network): host is the service name `db`, not localhost:
#   DATABASE_URL="postgresql://postgres:STRONG_PW@db:5432/unilink?schema=public"
